{
  "name": "astranova-desktop",
  "version": "1.0.0",
  "description": "Astranova AI Browser - Desktop Edition",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish=never",
    "build:mac": "electron-builder --mac --publish=never",
    "build:linux": "electron-builder --linux --publish=never",
    "dev": "electron . --dev"
  },
  "keywords": ["electron", "browser", "ai", "astranova"],
  "author": "Astranova Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fuzzynetwork1989-alt/astranova"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.astranova.browser",
    "productName": "Astranova Browser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "category": "Network"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "fuzzynetwork1989-alt",
      "repo": "astranova"
    }
  }
}
